# ──────────────────────────────────────────────────────────
# Apon Attendance Bridge — environment configuration
# Copy this file to `.env` (same directory) and fill in real values.
# ──────────────────────────────────────────────────────────

# Firebase service-account JSON. Download from:
#   Firebase Console → Project settings → Service accounts
#   → Generate new private key
# Save the JSON file outside source control and point to it here.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-sa.json

# Firestore project — must match the Flutter app's Firebase project.
FIREBASE_PROJECT_ID=attendance-app-apon

# Stable identifier for this bridge instance. If you ever run a second
# bridge (e.g. a second device at the back gate), give it a distinct
# ID so the two heartbeats don't overwrite each other.
BRIDGE_ID=front-gate

# ZKTeco device — IP, port, comm key (password). Defaults work for
# stock UFace800; change DEVICE_PASSWORD if you set one in the device
# menu.
DEVICE_IP=192.168.1.201
DEVICE_PORT=4370
DEVICE_PASSWORD=0
DEVICE_TIMEOUT=10
DEVICE_FORCE_UDP=false

# Logical name for this device, written into every punch record.
DEVICE_ID=uface800-front

# Poll interval (seconds). The bridge asks the device for new
# punches this often. Lower = lower latency, more device traffic.
POLL_INTERVAL_SECONDS=30

# Heartbeat interval (seconds). The bridge updates its bridges/{id}
# doc this often so the Flutter app can show "Last sync 5s ago".
HEARTBEAT_INTERVAL_SECONDS=30

# Local SQLite file for high-water-mark + processed command IDs.
STATE_DB_PATH=./bridge_state.sqlite
