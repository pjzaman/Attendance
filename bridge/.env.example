# ──────────────────────────────────────────────────────────
# Apon Attendance Bridge — environment configuration
#
# This file no longer carries device-connection settings. Those
# live in Firestore (devices/{targetDeviceId}) so HR can edit them
# from the Flutter app without touching this PC.
#
# All you set here is the bridge's identity and how it talks to
# Firebase. Everything else is in the cloud.
#
# The interactive installer (install\install.ps1) generates this
# file for you on a fresh install. You only edit it by hand if you
# want to override defaults later.
# ──────────────────────────────────────────────────────────

# Path to a Firebase service-account JSON. Download from
#   Firebase Console → Project settings → Service accounts
#   → Generate new private key
# Save next to apon-bridge.exe and reference by its filename here.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-sa.json

# The Firestore project this bridge writes into. Must match the
# project the service-account JSON belongs to. (The installer auto-
# detects this from the JSON when it generates your .env.)
FIREBASE_PROJECT_ID=attendance-app-apon

# Stable identifier for this bridge instance. If you ever run a
# second bridge on a different PC for a back-gate device, give it a
# distinct ID so the two heartbeats don't overwrite each other.
BRIDGE_ID=front-gate

# How often to poll the device for new punches (seconds).
POLL_INTERVAL_SECONDS=30

# How often to write a heartbeat (seconds).
HEARTBEAT_INTERVAL_SECONDS=30

# Local SQLite file for high-water-mark + processed command IDs.
STATE_DB_PATH=./bridge_state.sqlite
