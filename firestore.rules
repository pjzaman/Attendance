rules_version = '2';

// Apon Attendance — Firestore security rules.
//
// The Flutter app uses firedart for Firestore (cloud_firestore is
// broken on Windows desktop). firedart and firebase_auth are
// independent SDKs, so AuthService dual-signs-in to keep both
// authenticated; that's what makes `request.auth != null` work
// for legitimate clients.
//
// Caveat: Google sign-in users authenticate firebase_auth only,
// not firedart, so Firestore reads from a Google-only session
// will fail under these rules. Apon's deployment uses
// email/password — fine. Multi-tenant SaaS layer (which gets
// its own custom-token issuance via Cloud Functions) will close
// this gap.

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user prefs (starred reports, hidden columns, etc.).
    match /user_prefs/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Bridge heartbeat. Bridge writes via service account (bypasses
    // rules); clients only need to read.
    match /bridges/{bridgeId} {
      allow read, write: if request.auth != null;
    }

    // Punch records. Bridge writes via service account; clients
    // read for the live attendance dashboard.
    match /punches/{id} {
      allow read, write: if request.auth != null;
    }

    // Command queue. Clients enqueue (create), bridge updates with
    // results.
    match /bridge_commands/{id} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Default: any signed-in user has full access. Tighten with
    // per-collection role checks when ACL custom claims are wired.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
